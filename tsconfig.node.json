{
    "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
    "include": ["electron.vite.config.*", "scripts/**/*", "src/main/**/*", "src/preload/**/*", "src/shared/**/*"],
    "compilerOptions": {
        "composite": true,
        "types": ["electron-vite/node"],
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "baseUrl": ".",
        "paths": {
            "@shared/*": ["src/shared/*"],
            "@generated/*": ["src/shared/generated/*"]
        }
    }
}
